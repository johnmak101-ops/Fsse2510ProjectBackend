# ----------------------------------------------------
# Backend Environment Variables Template for Lightsail
# ----------------------------------------------------

# --- Java Options (JVM Tuning) ---
# JAVA_TOOL_OPTIONS=-Xms512m -Xmx1g -XX:MaxMetaspaceSize=160m -Xss512k -XX:+UseG1GC

# --- Database (MySQL) ---
DB_URL=jdbc:mysql
DB_USER=
DB_PASSWORD=

# --- Redis (Caching) ---
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# --- Security (Firebase/JWT) ---
JWT_ISSUER_URI=

# --- Application Limits/Settings ---
ADMIN_EMAILS=admin@user.com
APP_FRONTEND_URL=

# --- AWS (File Storage) ---
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
IMAGE_BASE_URL=

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
